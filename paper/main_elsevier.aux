\@writefile{lof}{\contentsline {figure}{\numberline {27}{\ignorespaces 3D matter power spectrum $P(k)$ of the reconstructed initial conditions ($64^3$ lattice). The high-$k$ tail follows $P(k) \propto k^{-3.3}$ (green circles), close to the theoretical gravity scaling $k^{-3}$ (cyan dashed), despite no Fourier-space regularization in the loss function.}}{48}{figure.27}\protected@file@percent }
\newlabel{fig:3dpk}{{27}{48}{3D matter power spectrum $P(k)$ of the reconstructed initial conditions ($64^3$ lattice). The high-$k$ tail follows $P(k) \propto k^{-3.3}$ (green circles), close to the theoretical gravity scaling $k^{-3}$ (cyan dashed), despite no Fourier-space regularization in the loss function}{figure.27}{}}
\newlabel{fig:3dpk@cref}{{[figure][27][]27}{[1][48][]48}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.16}Phenomenological visualization: continuing the lattice past the CMB epoch}{48}{subsection.4.16}\protected@file@percent }
\newlabel{sec:timeline}{{4.16}{48}{Phenomenological visualization: continuing the lattice past the CMB epoch}{subsection.4.16}{}}
\newlabel{sec:timeline@cref}{{[subsection][16][4]4.16}{[1][48][]48}}
\@writefile{lof}{\contentsline {figure}{\numberline {28}{\ignorespaces Breaking the projection degeneracy with 3D anchors (twin experiment, $48^3$ lattice). Top: 2D-only reconstruction perfectly fits the training hemisphere ($r = 1.00$) but fails on the held-out hemisphere ($r = -0.06$). Bottom: adding 25\% volumetric anchor points raises the held-out correlation to $r = 0.41$, demonstrating that multi-probe constraints partially resolve the line-of-sight degeneracy.}}{49}{figure.28}\protected@file@percent }
\newlabel{fig:degeneracy}{{28}{49}{Breaking the projection degeneracy with 3D anchors (twin experiment, $48^3$ lattice). Top: 2D-only reconstruction perfectly fits the training hemisphere ($r = 1.00$) but fails on the held-out hemisphere ($r = -0.06$). Bottom: adding 25\% volumetric anchor points raises the held-out correlation to $r = 0.41$, demonstrating that multi-probe constraints partially resolve the line-of-sight degeneracy}{figure.28}{}}
\newlabel{fig:degeneracy@cref}{{[figure][28][]28}{[1][48][]49}}
\@writefile{lof}{\contentsline {figure}{\numberline {29}{\ignorespaces Differentiable inverse reconstruction of the Planck SMICA CMB map. (a)\nobreakspace  {}Planck SMICA target ($N_{\mathrm  {side}}= 16$). (b)\nobreakspace  {}DSC reconstruction from $64^3$ initial conditions optimized via 150 Adam epochs. (c)\nobreakspace  {}Inferred 3D cosmic web (maximum intensity projection) with observation sphere (cyan dashed). (d)\nobreakspace  {}Loss convergence; final pixel correlation $r = 0.982$. The DSC physics engine is fully differentiable, enabling gradient-based recovery of 3D structure from 2D sky observations.}}{50}{figure.29}\protected@file@percent }
\newlabel{fig:inverse}{{29}{50}{Differentiable inverse reconstruction of the Planck SMICA CMB map. (a)~Planck SMICA target ($\nside = 16$). (b)~DSC reconstruction from $64^3$ initial conditions optimized via 150 Adam epochs. (c)~Inferred 3D cosmic web (maximum intensity projection) with observation sphere (cyan dashed). (d)~Loss convergence; final pixel correlation $r = 0.982$. The DSC physics engine is fully differentiable, enabling gradient-based recovery of 3D structure from 2D sky observations}{figure.29}{}}
\newlabel{fig:inverse@cref}{{[figure][29][]29}{[1][48][]50}}
\@writefile{lof}{\contentsline {figure}{\numberline {30}{\ignorespaces Phenomenological visualization of the lattice continued past the CMB-epoch step under an Allen--Cahn toy nonlinearity (\emph  {not} gravity). 12-panel overview, $128^3$. (a)\nobreakspace  {}Planck SMICA target. (b)\nobreakspace  {}DSC reconstructed CMB. (c)\nobreakspace  {}Big Bang initial state ($t = 0$). (d)\nobreakspace  {}CMB-epoch step. (e)\nobreakspace  {}Intermediate state. (f)\nobreakspace  {}Late-time domain-coarsened state (toy Allen--Cahn). (g)\nobreakspace  {}High-density regions. (h)\nobreakspace  {}Intermediate-density regions. (i)\nobreakspace  {}BB $\to $ CMB difference field: spatial pattern of $1/\qopname  \relax o{ln}^2$ cooling. (j)\nobreakspace  {}CMB $\to $ late difference field: regions dominated by the Allen--Cahn nonlinearity. (k)\nobreakspace  {}Optimization convergence of the inverse reconstruction. (l)\nobreakspace  {}V-shape phase transition: field variance drops during cooling (Phase\nobreakspace  {}I) and rises during Allen--Cahn coarsening (Phase\nobreakspace  {}II). Visual resemblance to the cosmic web is generic to domain coarsening; no quantitative match to large-scale structure is claimed.}}{52}{figure.30}\protected@file@percent }
\newlabel{fig:timeline}{{30}{52}{Phenomenological visualization of the lattice continued past the CMB-epoch step under an Allen--Cahn toy nonlinearity (\emph {not} gravity). 12-panel overview, $128^3$. (a)~Planck SMICA target. (b)~DSC reconstructed CMB. (c)~Big Bang initial state ($t = 0$). (d)~CMB-epoch step. (e)~Intermediate state. (f)~Late-time domain-coarsened state (toy Allen--Cahn). (g)~High-density regions. (h)~Intermediate-density regions. (i)~BB $\to $ CMB difference field: spatial pattern of $1/\ln ^2$ cooling. (j)~CMB $\to $ late difference field: regions dominated by the Allen--Cahn nonlinearity. (k)~Optimization convergence of the inverse reconstruction. (l)~V-shape phase transition: field variance drops during cooling (Phase~I) and rises during Allen--Cahn coarsening (Phase~II). Visual resemblance to the cosmic web is generic to domain coarsening; no quantitative match to large-scale structure is claimed}{figure.30}{}}
\newlabel{fig:timeline@cref}{{[figure][30][]30}{[1][51][]52}}
