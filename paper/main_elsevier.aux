\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Pillar\nobreakspace  {}K: instrument-resolved fits of the DSC $1/\qopname  \relax o{ln}^2(t)$ drift coefficient $\Gamma $ (in units of $10^{-5}$) on Murphy\nobreakspace  {}2003 + King\nobreakspace  {}2012 quasar samples, under both error budgets discussed in \cref  {sec:pillarA}. Budget (i): per-absorber fit error only (Pillar\nobreakspace  {}A convention). Budget (ii): Murphy's published $\sigma _{\rm  fit} \oplus \sigma _{\rm  rand}$. The Keck-only samples both prefer $\Gamma > 0$ at high significance; the VLT-only subset prefers $\Gamma $ of the opposite sign; the joint Keck+VLT union is consistent with $\Gamma = 0$ at $\sim 1.5$--$3.0\sigma $ depending on the budget.}}{20}{table.1}\protected@file@percent }
\newlabel{tab:pillarK_budgets}{{1}{20}{Pillar~K: instrument-resolved fits of the DSC $1/\ln ^2(t)$ drift coefficient $\Gamma $ (in units of $10^{-5}$) on Murphy~2003 + King~2012 quasar samples, under both error budgets discussed in \cref {sec:pillarA}. Budget (i): per-absorber fit error only (Pillar~A convention). Budget (ii): Murphy's published $\sigma _{\rm fit} \oplus \sigma _{\rm rand}$. The Keck-only samples both prefer $\Gamma > 0$ at high significance; the VLT-only subset prefers $\Gamma $ of the opposite sign; the joint Keck+VLT union is consistent with $\Gamma = 0$ at $\sim 1.5$--$3.0\sigma $ depending on the budget}{table.1}{}}
\newlabel{tab:pillarK_budgets@cref}{{[table][1][]1}{[1][20][]20}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Pillar\nobreakspace  {}K refined with Murphy 2003: forest plot of best-fit $\Gamma $ across instrument-resolved subsamples. Both independent Keck-only samples give $\Gamma > 0$ at $\sim 3\sigma $; the VLT-only subset gives $\Gamma $ of opposite sign; the full Keck$+$VLT union (rightmost) is consistent with $\Gamma = 0$ at $1.5\sigma $. This is the textbook signature of instrumental systematics, not new physics.}}{21}{figure.4}\protected@file@percent }
\newlabel{fig:pillar_K_murphy}{{4}{21}{Pillar~K refined with Murphy 2003: forest plot of best-fit $\Gamma $ across instrument-resolved subsamples. Both independent Keck-only samples give $\Gamma > 0$ at $\sim 3\sigma $; the VLT-only subset gives $\Gamma $ of opposite sign; the full Keck$+$VLT union (rightmost) is consistent with $\Gamma = 0$ at $1.5\sigma $. This is the textbook signature of instrumental systematics, not new physics}{figure.4}{}}
\newlabel{fig:pillar_K_murphy@cref}{{[figure][4][]4}{[1][21][]21}}
